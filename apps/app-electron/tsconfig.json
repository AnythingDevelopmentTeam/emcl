{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"outDir": "dist-electron",
		"rootDir": "electron",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"sourceMap": true
	},
	"include": ["electron/**/*"]
}
